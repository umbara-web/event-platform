# .env.test

NODE_ENV=test

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/event_platform_test"

# JWT
JWT_SECRET=test-jwt-secret-key-for-testing
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=test-refresh-secret-key-for-testing
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Email (Mock values for testing)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test-password
EMAIL_FROM=noreply@example.com

# Cloudinary (Mock values for testing)
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret

# Midtrans (Mock values for testing)
MIDTRANS_SERVER_KEY=test-server-key
MIDTRANS_CLIENT_KEY=test-client-key
MIDTRANS_IS_PRODUCTION=false

# Other
PORT=8000